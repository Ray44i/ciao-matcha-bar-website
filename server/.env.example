# ==========================================
# Ciao Matcha Bar Website
# Example Environment Configuration
# ==========================================

# Server Port
PORT=4000

# JWT Secret
JWT_SECRET=YOUR_JWT_SECRET_HERE

# Stripe Secret Key
# Leave empty or replace with your own local test key.
# DO NOT commit a real Stripe key to GitHub.
STRIPE_SECRET_KEY=

# Frontend URL
CLIENT_URL=http://localhost:5173

# Admin Setup Key
ADMIN_SETUP_KEY=YOUR_ADMIN_SETUP_KEY_HERE